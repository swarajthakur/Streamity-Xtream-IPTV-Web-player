# This file is COMMITTED to git — treat it as a template only.
# For real secrets (API keys, Xtream credentials), put them in `.env.local`
# which is already gitignored and overrides values here.

GENERATE_SOURCEMAP=false

# ---- TMDB ---------------------------------------------------------------
# Only one of the following is needed. Prefer the proxy (key stays server-side).
#
# Option A — server-side proxy (recommended): set the key in public/config.php
#   ($tmdb_api_key = "...") and enable here:
REACT_APP_TMDB_USE_PROXY=true
#
# Option B — build-time key (embedded in the JS bundle; less safe):
# REACT_APP_TMDB_API_KEY=

# ---- Xtream auto-login (optional) ---------------------------------------
# When ALL three are set, the /login/ screen is skipped and the app signs in
# automatically. Leave blank to use the interactive login form.
REACT_APP_XTREAM_DNS=http://dispatcharr.swat.im
REACT_APP_XTREAM_USERNAME=rapidiptv
REACT_APP_XTREAM_PASSWORD=builder123
