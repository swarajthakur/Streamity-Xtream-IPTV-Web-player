# Streamify backend config. Copy to server/.env and fill in.

# HTTP bind
HOST=0.0.0.0
PORT=8787

# Xtream provider DNS (no trailing slash). Must match the one used by the
# frontend; the /proxy.php endpoint refuses URLs outside this origin to
# prevent SSRF.
XTREAM_DNS=http://provider.example.com:80

# Set to "true" to enable the CORS proxy at /proxy.php. When false, the
# frontend should set window.cors = false and hit the provider directly.
PROXY_ENABLED=false

# TMDB v3 API key. When set, /tmdb.php proxies to api.themoviedb.org with
# this key appended. Leave blank to disable the TMDB proxy.
TMDB_API_KEY=

# SQLite database path (for EPG cache). Created on first run.
DB_PATH=./data/streamify.sqlite

# XMLTV EPG source. Either:
#   - a full URL (e.g. https://provider/xmltv.php?username=foo&password=bar)
#   - blank, in which case the frontend posts dns/username/password and the
#     URL is built on demand.
EPG_URL=

# Skip re-ingesting EPG if the average stop_timestamp is newer than
# (now - EPG_VALID_HOURS). Matches the old PHP behavior.
EPG_VALID_HOURS=12

# Optional: path to the built Vite frontend. When set, the server also
# serves it at /. Leave blank in dev (Vite's own dev server handles this).
STATIC_DIR=
