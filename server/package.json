{
  "name": "streamify-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Streamify backend — replaces proxy.php, tmdb.php, epg.php, epg-api.php with a single Fastify + better-sqlite3 service.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.1",
    "@fastify/static": "^8.0.2",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "sax": "^1.4.1",
    "undici": "^6.20.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.9",
    "@types/sax": "^1.2.7",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
